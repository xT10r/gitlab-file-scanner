#!/bin/sh
#
# Commit message hook for gitlab-file-scanner
# Validates Conventional Commits format: type(scope): description
#
# Installation:
#   cp .husky/commit-msg .git/hooks/commit-msg
#   chmod +x .git/hooks/commit-msg

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Skip merge commits
if echo "$commit_msg" | grep -qE "^Merge "; then
  exit 0
fi

# Skip revert commits
if echo "$commit_msg" | grep -qE "^Revert "; then
  exit 0
fi

# Conventional Commits regex
# type(scope): description (scope is REQUIRED)
PATTERN="^(feat|fix|refactor|docs|test|chore|ci|build)\([a-zA-Z0-9_-]+\)(!)?: .+"

if ! echo "$commit_msg" | grep -qE "$PATTERN"; then
  echo ""
  echo "ERROR: Invalid commit message format!"
  echo ""
  echo "Expected format: type(scope): description"
  echo ""
  echo "Types: feat, fix, refactor, docs, test, chore, ci, build"
  echo "Scope: package name (app, flags, api, file, text, cmd, docker, ci, deps)"
  echo ""
  echo "Examples:"
  echo "  feat(api): add context support for GitLab requests"
  echo "  fix(text): handle pluralization for numbers 11-14"
  echo "  chore(deps): update go.mod to Go 1.26"
  echo "  refactor(file)!: change ID type from int to int64"
  echo ""
  echo "Rules:"
  echo "  - English only"
  echo "  - Imperative mood (add, not added)"
  echo "  - No period at the end"
  echo "  - Lowercase first letter in description"
  echo ""
  exit 1
fi

exit 0
